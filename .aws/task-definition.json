{
  "family": "task-backjs",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::539241557920:role/LabRole",
  "taskRoleArn": "arn:aws:iam::539241557920:role/LabRole",
  "containerDefinitions": [
    {
      "name": "container-backjs",
      "image": "539241557920.dkr.ecr.us-east-1.amazonaws.com/backjs-eval3:latest",
      "portMappings": [
        {
          "containerPort": 8081,
          "hostPort": 8081
        }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/eval3-cluster-logs",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "backjs"
        }
      }
    }
  ]
}
